<h2><%= t("management.users.create_user_info") %></h2>

<div class="small-12 medium-6 column">

  <div class="verification account">
    <%= form_for @user, url: management_users_path do |f| %>
      <%= f.hidden_field :document_type %>
      <%= f.hidden_field :document_number %>
      <%= f.text_field :username,
                       label: t("management.username_label") %>
      <%= f.text_field :email,
                       label: t("management.account_info.email_label") %>
      <%= f.text_field :address, id: "address", label: t('custom.form.address'), required: true %>
      <!--
      <div class="date-of-birth">
        <%= f.date_select :date_of_birth,
                          prompt: true,
                          start_year: 1900, end_year: 16.years.ago.year,
                          label: t("management.date_of_birth") %>
      </div>
      -->
      <div>
      <%= f.check_box :data_consent, title: t('custom.terms.terms.terms_second_checkbox'), label: t("custom.terms.terms_second_checkbox") %>
      </div>
      <div>
      <%= f.check_box :terms_of_service,
        title: t("devise_views.users.registrations.new.terms"),
        label: t("devise_views.users.registrations.new.terms",
                 terms: link_to(t("devise_views.users.registrations.new.terms_link"), t("devise_views.users.registrations.new.terms_link"))
      ) %>
      </div>
      <%= f.submit t("management.users.create_user_submit"), class: "button success" %>
    <% end %>
  </div>
</div>

<div class="small-12 medium-6 column">
  <div class="callout">
    <%= render "management/user_permissions",
               message: t("management.document_verifications.in_census_has_following_permissions"),
               user: @user %>
  </div>
</div>
